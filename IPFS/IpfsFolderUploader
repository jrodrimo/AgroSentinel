package com.cirrusminor.ipfs.ipfs_folder_uploader;

import com.google.gson.Gson;
import com.google.gson.GsonBuilder;
import com.google.gson.JsonObject;
import com.google.gson.JsonParser;
import org.apache.hc.client5.http.classic.methods.HttpPost;
import org.apache.hc.client5.http.config.RequestConfig;
import org.apache.hc.client5.http.entity.mime.MultipartEntityBuilder;
import org.apache.hc.client5.http.impl.classic.CloseableHttpClient;
import org.apache.hc.client5.http.impl.classic.CloseableHttpResponse;
import org.apache.hc.client5.http.impl.classic.HttpClients;
import org.apache.hc.core5.http.ContentType;
import org.apache.hc.core5.http.HttpEntity;
import org.apache.hc.core5.http.io.entity.StringEntity;
import org.apache.hc.core5.util.Timeout;

import java.io.BufferedReader;
import java.io.BufferedWriter;
import java.io.FileInputStream;
import java.io.IOException;
import java.net.URI;
import java.net.URLEncoder;
import java.nio.charset.StandardCharsets;
import java.nio.file.*;
import java.security.MessageDigest;
import java.time.Instant;
import java.time.ZoneOffset;
import java.time.format.DateTimeFormatter;
import java.util.Properties;
import java.util.concurrent.*;
import java.util.concurrent.atomic.AtomicBoolean;
import java.util.regex.Matcher;
import java.util.regex.Pattern;

public class IpfsFolderUploader {

	private static final Pattern FILE_PATTERN =
		    Pattern.compile("^(estadoActual_.*|parrot_.*)\\.(jpg|jpeg|png)$", Pattern.CASE_INSENSITIVE);
	
    private static final DateTimeFormatter TS_FORMAT =
            DateTimeFormatter.ofPattern("yyyyMMdd'T'HHmmss'Z'").withZone(ZoneOffset.UTC);

    private static final Gson GSON = new GsonBuilder().setPrettyPrinting().create();

    private final Path watchDir;
    private final String ipfsApiBase;
    private final String fabricBridgeBase;
    private final String fabricSource;
    private final boolean sendToFabricEnabled;
    private final Path stateFile;
    private final int maxRetries;
    private final long initialRetryDelayMs;
    private final long stabilityWaitMs;
    private final int stabilityChecks;

    private final ConcurrentMap<String, AtomicBoolean> inFlightByPath = new ConcurrentHashMap<>();
    private final ConcurrentMap<String, Long> recentFingerprints = new ConcurrentHashMap<>();
    private final ScheduledExecutorService retryExecutor = Executors.newScheduledThreadPool(2);
    private final ExecutorService workerExecutor = Executors.newFixedThreadPool(4);

    public IpfsFolderUploader(Properties props) {
        this.watchDir = Paths.get(require(props, "watch.dir")).toAbsolutePath().normalize();
        this.ipfsApiBase = props.getProperty("ipfs.api.base", "http://127.0.0.1:5001");
        this.fabricBridgeBase = props.getProperty("fabric.bridge.base", "http://192.168.136.130:8088");
        this.fabricSource = props.getProperty("fabric.source", "windows-ipfs-uploader");
        this.sendToFabricEnabled = Boolean.parseBoolean(props.getProperty("fabric.enabled", "true"));
        this.stateFile = Paths.get(props.getProperty("state.file", "processed-state.jsonl")).toAbsolutePath().normalize();
        this.maxRetries = Integer.parseInt(props.getProperty("retry.max.attempts", "5"));
        this.initialRetryDelayMs = Long.parseLong(props.getProperty("retry.initial.delay.ms", "3000"));
        this.stabilityWaitMs = Long.parseLong(props.getProperty("file.stability.wait.ms", "700"));
        this.stabilityChecks = Integer.parseInt(props.getProperty("file.stability.checks", "10"));
    }

    public static void main(String[] args) throws Exception {
        Properties props = new Properties();
        try (FileInputStream fis = new FileInputStream("config.properties")) {
            props.load(fis);
        }

        IpfsFolderUploader uploader = new IpfsFolderUploader(props);
        uploader.start();
    }

    public void start() throws Exception {
        log("INFO", "Vigilando carpeta: " + watchDir);
        log("INFO", "IPFS API: " + ipfsApiBase);
        log("INFO", "Fabric Bridge API: " + fabricBridgeBase);
        log("INFO", "Envío a Fabric habilitado: " + sendToFabricEnabled);
        log("INFO", "Fichero de estado: " + stateFile);

        Files.createDirectories(watchDir);
        ensureStateFileExists();

        Runtime.getRuntime().addShutdownHook(new Thread(this::shutdownExecutors));

        try (WatchService watchService = FileSystems.getDefault().newWatchService()) {
            watchDir.register(
                    watchService,
                    StandardWatchEventKinds.ENTRY_CREATE,
                    StandardWatchEventKinds.ENTRY_MODIFY
            );

            log("INFO", "WatchService registrado correctamente");

            while (true) {
                WatchKey key = watchService.take();

                for (WatchEvent<?> event : key.pollEvents()) {
                    if (event.kind() == StandardWatchEventKinds.OVERFLOW) {
                        log("WARN", "WatchService overflow detectado");
                        continue;
                    }

                    Path relative = (Path) event.context();
                    Path file = watchDir.resolve(relative).toAbsolutePath().normalize();

                    if (!Files.isRegularFile(file) || !matches(file)) {
                        continue;
                    }

                    submitFile(file, event.kind().name());
                }

                if (!key.reset()) {
                    throw new IllegalStateException("WatchKey inválida o carpeta no disponible");
                }
            }
        }
    }

    private void submitFile(Path file, String eventType) {
        String pathKey = file.toString();
        AtomicBoolean flag = inFlightByPath.computeIfAbsent(pathKey, k -> new AtomicBoolean(false));

        if (!flag.compareAndSet(false, true)) {
            log("DEBUG", "Ignorando evento duplicado en curso para: " + pathKey + " (" + eventType + ")");
            return;
        }

        workerExecutor.submit(() -> {
            try {
                log("INFO", "Evento " + eventType + " detectado para " + pathKey);
                processFileWithRetry(file, 1);
            } finally {
                flag.set(false);
            }
        });
    }

    private void processFileWithRetry(Path path, int attempt) {
        try {
            processFile(path);
        } catch (Exception e) {
            if (attempt >= maxRetries) {
                log("ERROR", "Fallo definitivo tras " + attempt + " intentos para " + path + ": " + e.getMessage());
                e.printStackTrace();
                return;
            }

            long delay = initialRetryDelayMs * (1L << (attempt - 1));
            log("WARN", "Error procesando " + path + " (intento " + attempt + "/" + maxRetries + "). Reintento en "
                    + delay + " ms. Motivo: " + e.getMessage());

            retryExecutor.schedule(() -> processFileWithRetry(path, attempt + 1), delay, TimeUnit.MILLISECONDS);
        }
    }

    private void processFile(Path path) throws Exception {
        waitUntilStable(path);

        String fileName = path.getFileName().toString();
        long size = Files.size(path);
        long mtime = Files.getLastModifiedTime(path).toMillis();
        String sha256 = computeSha256(path);

        String eventFingerprint = fileName + "|" + size + "|" + mtime + "|" + sha256;
        if (isRecentDuplicate(eventFingerprint)) {
            log("INFO", "Evento duplicado reciente ignorado para " + fileName);
            return;
        }

        String timestamp = Instant.now().toString();
        String assetId = buildUniqueAssetId(fileName, sha256, timestamp);
        String mfsPath = buildUniqueMfsPath(fileName, sha256, timestamp);

        log("INFO", "Procesando file=" + fileName + ", assetId=" + assetId);

        String cid = uploadToIpfs(path);
        copyToMfs(cid, mfsPath);

        JsonObject fabricResponse = null;
        if (sendToFabricEnabled) {
            fabricResponse = sendToFabric(assetId, cid, sha256, timestamp, fabricSource);
        }

        FileRecord record = new FileRecord();
        record.assetId = assetId;
        record.fileName = fileName;
        record.sha256 = sha256;
        record.cid = cid;
        record.timestamp = timestamp;
        record.source = fabricSource;
        record.fabricEnabled = sendToFabricEnabled;
        record.fabricResponse = fabricResponse == null ? null : fabricResponse.toString();
        record.mfsPath = mfsPath;
        record.fileSize = size;
        record.lastModified = mtime;

        appendState(record);
        rememberRecent(eventFingerprint);

        log("INFO", "Procesado OK");
        log("INFO", "  Archivo   : " + fileName);
        log("INFO", "  Asset ID  : " + assetId);
        log("INFO", "  CID       : " + cid);
        log("INFO", "  MFS Path  : " + mfsPath);
        log("INFO", "  SHA-256   : " + sha256);
        log("INFO", "  Timestamp : " + timestamp);
    }

    private boolean matches(Path path) {
        return FILE_PATTERN.matcher(path.getFileName().toString()).matches();
    }

    private String buildUniqueAssetId(String fileName, String sha256, String timestamp) {
        String base;
        Matcher matcher = FILE_PATTERN.matcher(fileName);
        if (matcher.matches()) {
            base = "asset" + matcher.group(1);
        } else {
            int dot = fileName.lastIndexOf('.');
            base = dot > 0 ? fileName.substring(0, dot) : fileName;
            base = base.replaceAll("[^a-zA-Z0-9_-]", "_");
        }

        String shortHash = sha256.substring(0, 12);
        String ts = TS_FORMAT.format(Instant.parse(timestamp));
        return base + "_" + ts + "_" + shortHash;
    }

    private String buildUniqueMfsPath(String fileName, String sha256, String timestamp) {
        String safeName = sanitizeFileName(fileName);
        String shortHash = sha256.substring(0, 12);
        String ts = TS_FORMAT.format(Instant.parse(timestamp));
        return "/cassini/" + ts + "_" + shortHash + "_" + safeName;
    }

    private String sanitizeFileName(String fileName) {
        return fileName.replaceAll("[^a-zA-Z0-9._-]", "_");
    }

    private boolean isRecentDuplicate(String fingerprint) {
        Long existing = recentFingerprints.get(fingerprint);
        if (existing == null) {
            return false;
        }
        long ageMs = System.currentTimeMillis() - existing;
        return ageMs < 15_000;
    }

    private void rememberRecent(String fingerprint) {
        long now = System.currentTimeMillis();
        recentFingerprints.put(fingerprint, now);

        recentFingerprints.entrySet().removeIf(e -> (now - e.getValue()) > 60_000);
    }

    private void waitUntilStable(Path path) throws Exception {
        long prevSize = -1;
        long prevMtime = -1;

        for (int i = 0; i < stabilityChecks; i++) {
            long size = Files.size(path);
            long mtime = Files.getLastModifiedTime(path).toMillis();

            if (size > 0 && size == prevSize && mtime == prevMtime) {
                return;
            }

            prevSize = size;
            prevMtime = mtime;
            Thread.sleep(stabilityWaitMs);
        }

        throw new IllegalStateException("El archivo no llegó a estabilizarse: " + path);
    }

    private String computeSha256(Path path) throws Exception {
        MessageDigest digest = MessageDigest.getInstance("SHA-256");
        byte[] bytes = Files.readAllBytes(path);
        byte[] hash = digest.digest(bytes);

        StringBuilder hex = new StringBuilder();
        for (byte b : hash) {
            hex.append(String.format("%02x", b));
        }
        return hex.toString();
    }

    private String uploadToIpfs(Path path) throws Exception {
        String url = ipfsApiBase + "/api/v0/add?pin=true";

        RequestConfig config = RequestConfig.custom()
                .setResponseTimeout(Timeout.ofMinutes(2))
                .build();

        try (CloseableHttpClient client = HttpClients.custom()
                .setDefaultRequestConfig(config)
                .build()) {

            HttpPost post = new HttpPost(URI.create(url));
            post.setEntity(MultipartEntityBuilder.create()
                    .addBinaryBody(
                            "file",
                            path.toFile(),
                            ContentType.APPLICATION_OCTET_STREAM,
                            path.getFileName().toString()
                    )
                    .build());

            try (CloseableHttpResponse response = client.execute(post)) {
                int status = response.getCode();
                String body = readBody(response.getEntity());

                if (status < 200 || status >= 300) {
                    throw new IllegalStateException("IPFS add HTTP " + status + ": " + body);
                }

                JsonObject json = JsonParser.parseString(body).getAsJsonObject();
                if (!json.has("Hash")) {
                    throw new IllegalStateException("Respuesta IPFS sin Hash: " + body);
                }

                return json.get("Hash").getAsString();
            }
        }
    }

    private void copyToMfs(String cid, String targetMfsPath) throws Exception {
        ensureDir("/cassini");

        String url = ipfsApiBase + "/api/v0/files/cp?arg="
                + URLEncoder.encode("/ipfs/" + cid, StandardCharsets.UTF_8)
                + "&arg="
                + URLEncoder.encode(targetMfsPath, StandardCharsets.UTF_8);

        try (CloseableHttpClient client = HttpClients.createDefault()) {
            HttpPost post = new HttpPost(url);

            try (CloseableHttpResponse response = client.execute(post)) {
                int status = response.getCode();
                String body = readBody(response.getEntity());
                if (status < 200 || status >= 300) {
                    throw new IllegalStateException("MFS copy HTTP " + status + ": " + body);
                }
            }
        }
    }

    private void ensureDir(String dir) throws Exception {
        String url = ipfsApiBase + "/api/v0/files/mkdir?arg="
                + URLEncoder.encode(dir, StandardCharsets.UTF_8)
                + "&parents=true";

        try (CloseableHttpClient client = HttpClients.createDefault()) {
            HttpPost post = new HttpPost(url);

            try (CloseableHttpResponse response = client.execute(post)) {
                int status = response.getCode();
                String body = readBody(response.getEntity());
                if (status < 200 || status >= 300) {
                    throw new IllegalStateException("MFS mkdir HTTP " + status + ": " + body);
                }
            }
        }
    }

    private JsonObject sendToFabric(String assetId, String cid, String sha256, String timestamp, String source) throws Exception {
        String url = fabricBridgeBase + "/fabric/register";

        JsonObject payload = new JsonObject();
        payload.addProperty("id", assetId);
        payload.addProperty("cid", cid);
        payload.addProperty("sha256", sha256);
        payload.addProperty("timestamp", timestamp);
        payload.addProperty("source", source);

        RequestConfig config = RequestConfig.custom()
                .setResponseTimeout(Timeout.ofMinutes(1))
                .build();

        try (CloseableHttpClient client = HttpClients.custom()
                .setDefaultRequestConfig(config)
                .build()) {

            HttpPost post = new HttpPost(URI.create(url));
            post.setHeader("Content-Type", "application/json");
            post.setEntity(new StringEntity(payload.toString(), ContentType.APPLICATION_JSON));

            try (CloseableHttpResponse response = client.execute(post)) {
                int status = response.getCode();
                String body = readBody(response.getEntity());

                if (status < 200 || status >= 300) {
                    throw new IllegalStateException("Fabric register HTTP " + status + ": " + body);
                }

                JsonObject json = JsonParser.parseString(body).getAsJsonObject();
                if (json.has("ok") && !json.get("ok").getAsBoolean()) {
                    throw new IllegalStateException("Fabric respondió ok=false: " + body);
                }

                return json;
            }
        }
    }

    private String readBody(HttpEntity entity) throws Exception {
        if (entity == null) {
            return "";
        }
        return new String(entity.getContent().readAllBytes(), StandardCharsets.UTF_8);
    }

    private synchronized void ensureStateFileExists() throws IOException {
        Path parent = stateFile.getParent();
        if (parent != null) {
            Files.createDirectories(parent);
        }
        if (!Files.exists(stateFile)) {
            Files.createFile(stateFile);
        }
    }

    private synchronized void appendState(FileRecord record) throws IOException {
        try (BufferedWriter writer = Files.newBufferedWriter(
                stateFile,
                StandardCharsets.UTF_8,
                StandardOpenOption.CREATE,
                StandardOpenOption.APPEND
        )) {
            writer.write(GSON.toJson(record));
            writer.newLine();
            writer.flush();
        }
    }

    private void shutdownExecutors() {
        log("INFO", "Apagando ejecutores...");
        shutdownExecutor(workerExecutor, "workerExecutor");
        shutdownExecutor(retryExecutor, "retryExecutor");
    }

    private void shutdownExecutor(ExecutorService executor, String name) {
        executor.shutdown();
        try {
            if (!executor.awaitTermination(10, TimeUnit.SECONDS)) {
                log("WARN", name + " no terminó a tiempo; forzando shutdownNow()");
                executor.shutdownNow();
            }
        } catch (InterruptedException e) {
            Thread.currentThread().interrupt();
            executor.shutdownNow();
        }
    }

    private static String require(Properties props, String key) {
        String value = props.getProperty(key);
        if (value == null || value.isBlank()) {
            throw new IllegalArgumentException("Falta propiedad obligatoria: " + key);
        }
        return value;
    }

    private static void log(String level, String message) {
        System.out.println("[" + Instant.now() + "] [" + level + "] " + message);
    }

    private static class FileRecord {
        String assetId;
        String fileName;
        String sha256;
        String cid;
        String timestamp;
        String source;
        boolean fabricEnabled;
        String fabricResponse;
        String mfsPath;
        long fileSize;
        long lastModified;
    }
}
